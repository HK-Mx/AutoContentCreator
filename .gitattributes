# Auto convert line endings for Windows/Linux/Mac
* text=auto

# Code files
*.py text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Binary files
*.mp4 binary
*.mov binary
*.avi binary
*.mkv binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.tar.gz binary
