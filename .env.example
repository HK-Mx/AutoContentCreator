# ========== COPY THIS FILE TO .env AND FILL WITH YOUR ACTUAL KEYS ==========
# IMPORTANTE: NUNCA subas .env a GitHub. Solo .env.example
# RUN: cp .env.example .env

# ========== APIs - LLMs ==========
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ========== APIs - Social Media & Stock ==========
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
YOUTUBE_ACCESS_TOKEN=your_youtube_access_token_here
YOUTUBE_CLIENT_SECRET_PATH=./config/youtube_secret.json
PEXELS_API_KEY=your_pexels_api_key_here

# ========== AWS S3 ==========
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=eu-west-1
S3_BUCKET_NAME=autonomous-agents-videos

# ========== Database ==========
DATABASE_URL=postgresql://user:password@localhost:5432/autonomous_agents
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_KEY=your_supabase_key_here

# ========== Cache ==========
REDIS_URL=redis://localhost:6379

# ========== Email Reporting ==========
ADMIN_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_specific_password_here

# ========== App Config ==========
OLLAMA_HOST=http://localhost:11434
DEBUG=False
LOG_LEVEL=INFO
ENVIRONMENT=production

# ========== Features ==========
ENABLE_MULTI_TENANT=True
DEFAULT_REGION=es
SUPPORTED_REGIONS=es,us,mx,br,fr
ENABLE_VERBOSE_LOGGING=False

# ========== Timeouts (en segundos) ==========
API_TIMEOUT_SECONDS=30
VIDEO_GENERATION_TIMEOUT=600
